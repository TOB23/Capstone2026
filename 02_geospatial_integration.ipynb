    "# ============================================================\n",
    "# VERIFY SCHEMA WITH SYNTHETIC DATA\n",
    "# This cell creates a synthetic master table to validate\n",
    "# the schema and downstream pipeline before real data is ready.\n",
    "# ============================================================\n",
    "\n",
    "from sklearn.datasets import make_classification\n",
    "\n",
    "FEATURE_COLS = [\n",
    "    \"ugrd_10m_mean\", \"vgrd_10m_mean\", \"gust_sfc_max\", \"gust_sfc_mean\",\n",
    "    \"ugrd_shear_mean\", \"vgrd_shear_mean\", \"cape_sfc_mean\", \"cape_sfc_max\",\n",
    "    \"cin_sfc_mean\", \"hlcy_3km_mean\", \"pwat_clm_mean\",\n",
    "    \"apcp_sfc_mean\", \"apcp_sfc_max\", \"soilw_0_10_mean\",\n",
    "    \"wind_shear_mag_mean\", \"wind_gust_x_soilw\", \"wind_gust_x_apcp\",\n",
    "    \"cape_x_shear\", \"wind_speed_10m_mean\",\n",
    "    \"forest_fraction\", \"pop_density\",\n",
    "]\n",
    "\n",
    "N_SYNTHETIC = 50_000\n",
    "\n",
    "np.random.seed(42)\n",
    "X_syn, y_syn = make_classification(\n",
    "    n_samples=N_SYNTHETIC,\n",
    "    n_features=len(FEATURE_COLS),\n",
    "    n_informative=12,\n",
    "    n_redundant=4,\n",
    "    weights=[0.97, 0.03],  # ~3% outage rate (class imbalance)\n",
    "    random_state=42,\n",
    ")\n",
    "\n",
    "master_syn = pd.DataFrame(X_syn, columns=FEATURE_COLS)\n",
    "master_syn[\"outage_event\"] = y_syn\n",
    "master_syn[\"fips\"] = np.random.choice(counties[\"STATEFP\"] + counties[\"COUNTYFP\"], N_SYNTHETIC)\n",
    "master_syn[\"valid_time_3h\"] = pd.date_range(\"2021-01-01\", periods=N_SYNTHETIC, freq=\"3H\")\n",
    "master_syn[\"split\"] = np.where(master_syn[\"valid_time_3h\"].dt.year <= 2022, \"train\", \"test\")\n",
    "\n",
    "master_syn.to_parquet(DATA_PROC / \"master_table_SYNTHETIC.parquet\", index=False)\n",
    "\n",
    "print(f\"Synthetic master table: {master_syn.shape}\")\n",
    "print(f\"Outage rate: {master_syn['outage_event'].mean()*100:.2f}%\")\n",
    "print(f\"Features: {FEATURE_COLS}\")\n",
