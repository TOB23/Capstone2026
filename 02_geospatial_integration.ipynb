   "source": [
    "# ============================================================\n",
    "# STATIC FEATURES: Forest fraction (Tervo et al. 2021 concept)\n",
    "# Uses NLCD 2021 data. If unavailable, uses a placeholder.\n",
    "#\n",
    "# To get real NLCD data:\n",
    "#   https://www.mrlc.gov/viewer/  → download NLCD 2021 Land Cover\n",
    "#   Then compute % of forested classes (41, 42, 43) per county.\n",
    "# ============================================================\n",
    "\n",
    "def build_static_features(counties_gdf: gpd.GeoDataFrame) -> pd.DataFrame:\n",
    "    \"\"\"\n",
    "    Build static (time-invariant) county-level features.\n",
    "    Returns DataFrame indexed by 5-digit FIPS.\n",
    "    \"\"\"\n",
    "    static = counties_gdf[[\"STATEFP\", \"COUNTYFP\", \"ALAND\"]].copy()\n",
    "    static[\"fips\"] = static[\"STATEFP\"] + static[\"COUNTYFP\"]\n",
    "    static = static.set_index(\"fips\")\n",
    "\n",
    "    # Land area in km2\n",
    "    static[\"land_area_km2\"] = static[\"ALAND\"] / 1e6\n",
    "\n",
    "    # Placeholder forest fraction — replace with NLCD values\n",
    "    # Typical Midwest range: ~0.05 (IL agriculture) to ~0.55 (MI upper peninsula)\n",
    "    np.random.seed(42)\n",
    "    static[\"forest_fraction\"] = np.random.uniform(0.05, 0.55, len(static))\n",
    "    print(\"⚠️  forest_fraction is a placeholder — replace with NLCD 2021 data\")\n",
    "\n",
    "    # Population density placeholder — replace with Census ACS data\n",
    "    # (customers_per_km2 is a reasonable proxy)\n",
    "    static[\"pop_density\"] = np.random.uniform(10, 2000, len(static))\n",
    "    print(\"⚠️  pop_density is a placeholder — replace with Census ACS data\")\n",
    "\n",
    "    return static[[\"land_area_km2\", \"forest_fraction\", \"pop_density\"]]\n",
    "\n",
    "\n",
    "static_features = build_static_features(counties)\n",
    "print(f\"\\nStatic features shape: {static_features.shape}\")\n",
    "static_features.head()"
   ]
  },
