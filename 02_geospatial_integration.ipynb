   "source": [
    "# ============================================================\n",
    "# MASTER TRAINING TABLE BUILDER\n",
    "# Merges GEFS features (by valid_time) with EAGLE-I labels.\n",
    "#\n",
    "# NOTE: This cell is scaffolded — actual GEFS feature loading\n",
    "# depends on the GRIB2 files downloaded in Notebook 1.\n",
    "# Replace `load_gefs_features_for_date()` with your actual loader.\n",
    "# ============================================================\n",
    "\n",
    "def load_gefs_features_for_date(valid_date_str: str, spatial_index, lon_flat, lat_flat):\n",
    "    \"\"\"\n",
    "    Load GEFSv12 GRIB2 files for a given date, extract county-level\n",
    "    neighborhood features, and return a feature DataFrame.\n",
    "    \n",
    "    Placeholder: replace with actual xr.open_dataset calls once\n",
    "    files are downloaded in Notebook 1.\n",
    "    \"\"\"\n",
    "    # TODO: replace with real GRIB2 loading\n",
    "    # ds_dict = {var: xr.open_dataset(GEFS_DIR / year / fname, engine='cfgrib') ...}\n",
    "    # features_df = extract_county_features(ds_dict, spatial_index, lon_flat, lat_flat)\n",
    "    # features_df = engineer_compound_features(features_df)\n",
    "    # return features_df\n",
    "    raise NotImplementedError(\"Replace with real GRIB2 loader from Notebook 1\")\n",
    "\n",
    "\n",
    "def build_master_table(\n",
    "    aligned_df: pd.DataFrame,\n",
    "    static_features_df: pd.DataFrame,\n",
    "    spatial_index: dict,\n",
    "    lon_flat: np.ndarray,\n",
    "    lat_flat: np.ndarray,\n",
    ") -> pd.DataFrame:\n",
    "    \"\"\"\n",
    "    Iterate over unique dates in aligned_df, load GEFS features,\n",
    "    and join with outage labels + static features.\n",
    "    \"\"\"\n",
    "    all_rows = []\n",
    "    dates = aligned_df[\"valid_time_3h\"].dt.date.unique()\n",
    "\n",
    "    for dt in tqdm(dates, desc=\"Building master table\"):\n",
    "        dt_str = pd.Timestamp(dt).strftime(\"%Y%m%d\")\n",
    "\n",
    "        try:\n",
    "            gefs_features = load_gefs_features_for_date(dt_str, spatial_index, lon_flat, lat_flat)\n",
    "        except NotImplementedError:\n",
    "            continue  # Skip until real loader is implemented\n",
    "        except Exception as e:\n",
    "            print(f\"  Error on {dt_str}: {e}\")\n",
    "            continue\n",
    "\n",
    "        # Filter outage labels for this date\n",
    "        day_mask = aligned_df[\"valid_time_3h\"].dt.date == dt\n",
    "        day_labels = aligned_df[day_mask].copy()\n",
    "\n",
    "        # Merge GEFS features\n",
    "        merged = day_labels.merge(gefs_features, left_on=\"fips\", right_index=True, how=\"left\")\n",
    "        # Merge static features\n",
    "        merged = merged.merge(static_features_df, left_on=\"fips\", right_index=True, how=\"left\")\n",
    "        all_rows.append(merged)\n",
    "\n",
    "    if all_rows:\n",
    "        master = pd.concat(all_rows, ignore_index=True)\n",
    "        return master\n",
    "    else:\n",
    "        print(\"No rows assembled yet — GEFS loader not yet implemented.\")\n",
    "        return pd.DataFrame()\n",
    "\n",
    "\n",
    "print(\"Master table builder defined.\")\n",
    "print(\"Next step: implement load_gefs_features_for_date() once GRIB2 files are downloaded.\")"
   ]
  },
